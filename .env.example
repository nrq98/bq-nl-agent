# .env.example
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas el .env a GitHub (ya está en .gitignore).

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Obtén tu API key en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Cloud ───────────────────────────────────────────────────────────────
# ID de tu proyecto de GCP (obligatorio)
GCP_PROJECT_ID=mi-proyecto-gcp

# Opción A — Service Account (ruta al fichero JSON de credenciales)
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/service-account.json

# Opción B — Application Default Credentials
# Ejecuta: gcloud auth application-default login
# Y deja esta variable sin definir.

# ── Esquema ────────────────────────────────────────────────────────────────────
# Ruta al fichero YAML con el esquema de tus tablas (por defecto: schema.yaml)
# BQ_SCHEMA_PATH=schema.yaml

# ── Logging ────────────────────────────────────────────────────────────────────
# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
